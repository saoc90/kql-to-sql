let a = datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ]; let b = a | summarize count() by k; let c = b | extend Column1 = count_; let d = c | summarize count_ = sum(count_), Column1 = sum(Column1) by k; d | join kind=inner (b) on k | project k, count_, Column1, count_1 | sort by k asc
let s0 = datatable(["select"]:long, ["from"]:long, ["order"]:long)[ 1,2,3, 4,5,6 ]; let s1 = s0 | extend ["group"] = ["select"] + ["from"]; let s2 = s1 | where ["group"] > 3; let s3 = s2 | summarize ["count"] = count(), ["table"] = sum(["order"]) by ["group"]; s3 | project ["group"], ["count"], ["table"] | sort by ["group"] asc
let m = materialize(datatable(k:long, v:long)[ 1,10, 1,20, 2,30 ] | summarize s = sum(v), c = count() by k); m | join kind=inner (m | extend s = s + 1) on k | join kind=leftouter (m | project k, c) on k | project k, s, s1, c, c1, c2 | sort by k asc
print x = 1 | extend x = x + 1 | extend x = x + 1 | extend x = x + 1 | extend y = x | extend x = y * x | project x, y
let r0 = range x from 1 to 6 step 1; let r1 = r0 | extend grp = x % 3; let r2 = r1 | summarize lst = make_list(x) by grp; let r3 = r2 | mv-expand val = lst to typeof(long); let r4 = r3 | summarize cnt = count(), tot = sum(val) by grp; r4 | sort by grp asc
datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ] | summarize count() by k | as Stage1 | extend count_ = count_ + 100 | join kind=inner (Stage1) on k | project k, count_, count_1 | sort by k asc
let base = datatable(i:int, l:long, r:real)[ -5,-5,-5.5, 0,0,0.0, 3,2147483648,0.1, 7,100,3.25 ]; let p1 = base | where i > -10 | where r < 100; let p2 = p1 | where i != 0 | where r > -100; let p3 = p2 | where i < 3 | where i > 3; p3 | project i | sort by i asc
let t = datatable(g:string, v:long)[ "a",1, "a",2, "b",3, "b",4, "c",5 ]; let agg = t | summarize total = sum(v), lst = make_list(v) by g; let exploded = agg | mv-expand item = lst to typeof(long); exploded | summarize back = sum(item), tot2 = max(total) by g | extend ok = back == tot2 | sort by g asc
print value = 10, count = 20, sum = 30 | extend avg = (value + count + sum) / 3 | extend min = value - count | extend max = sum + count | project max, min, avg, sum, count, value
datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ] | summarize arg_max(v, *) by k | extend k = k * 10 | summarize arg_min(v, *) by k | project k, v | sort by k asc
let d = datatable(d:dynamic)[ dynamic({"a":1,"b":[1,2,3]}), dynamic({"a":2,"b":[4,5]}), dynamic({"a":3,"b":[6]}) ]; let e = d | extend a = toint(d.a), arr = d.b; let f = e | mv-expand x = arr to typeof(long); f | summarize s = sum(x), cnt = count() by a | sort by a asc
let g = datatable(k:long, v:long)[ 1,10, 2,20, 3,30 ]; let h = g | extend v = v + 1; let i2 = h | extend v = v * 2; let j = i2 | summarize sum(v); g | union (j | extend k = 99) | sort by k asc
datatable(s:string, tag:string)[ "alpha","x", "Beta","x", "café","y", "","z", "O'Brien","x" ] | summarize Column1 = count(), Column2 = make_list(s) by tag | mv-expand Column2 | project tag, Column1, Column2 | sort by tag asc, tostring(Column2) asc
let z = datatable(n:long)[ 1, 2, 3, 4, 5 ]; let s = toscalar(z | summarize sum(n)); let m = toscalar(z | summarize max(n)); z | extend frac = n * 100 / s | extend norm = n * 100 / m | project n, frac, norm | sort by n asc
datatable(i:int)[ 1, 2, 3, 4, 5, 6 ] | extend grp = i % 2 | partition by grp (summarize s = sum(i) | extend tag = "p") | sort by s asc
let l1 = datatable(k:long, v:long)[ 1,5, 2,10, 3,15 ]; let l2 = l1 | extend w = v * 2; let l3 = l2 | extend v = w; let l4 = l3 | extend w = v + 1; l4 | project k, v, w | sort by k asc
datatable(id:long, name:string, score:real, active:bool, ts:datetime, cat:string)[ 1,"a",1.5,true,datetime(2020-01-01),"p", 2,"b",2.5,false,datetime(2021-06-01),"q" ] | project-rename value = score, count = id | extend table = strcat(name, cat) | project-reorder count, value, table | sort by count asc
let r = range x from 1 to 4 step 1; let pivoted = r | summarize lst = make_list(x); let widened = pivoted | extend a = lst[0], b = lst[1], c = lst[2], d = lst[3]; widened | project a, b, c, d
datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ] | summarize make_set(v) by k | mv-expand set_v to typeof(long) | summarize make_list(set_v) by k | extend joined = strcat_array(list_set_v, "-") | project k, joined | sort by k asc
let outer = datatable(k:long, v:long)[ 1,5, 2,10, 3,15 ]; let inner = datatable(k:long, w:long)[ 1,7, 1,8, 2,9 ]; outer | join kind=leftouter (inner | summarize mw = max(w), cw = count() by k) on k | extend gap = coalesce(mw, 0) - v | extend has = isnull(mw) | project k, v, mw, cw, gap, has | sort by k asc
print p = "x" | extend print_0 = p | extend print_1 = strcat(print_0, "y") | project print_0, print_1, p
datatable(a:long, b:long, c:long)[ 1,2,3, 4,5,6, 7,8,9 ] | extend a = c, c = a | project a, b, c | extend b = a + c | project-reorder c, b, a | sort by a asc
let nums = datatable(i:int, l:long, r:real)[ -5,-5,-5.5, 0,0,0.0, 3,2147483648,0.1, 7,100,3.25 ]; let s1 = nums | extend cat = case(i < 0, "neg", i == 0, "zero", "pos"); let s2 = s1 | summarize cnt = count(), avgr = avg(r) by cat; let s3 = s2 | sort by cnt desc; s3 | extend rn = row_number() | project rn, cat, cnt, avgr
datatable(k:long, v:long)[ 1,10, 2,20, 3,30, 4,40 ] | where v > 5 | summarize total = sum(v) | extend total = total + 1 | extend total = total * 2 | project total
let f = datatable(g:string, v:long)[ "a",1, "a",2, "b",3, "b",4 ]; f | summarize lst = make_list(v) by g | mv-apply x = lst to typeof(long) on (summarize sm = sum(x), mx = max(x)) | extend ratio = mx * 1.0 / sm | project g, sm, mx, ratio | sort by g asc
print n = 3 | extend arr = range(0, n, 1) | mv-expand e = arr to typeof(long) | extend sq = e * e | summarize cnt = count(), total = sum(sq), lst = make_list(sq)
let t1 = datatable(k:long, v:long)[ 1,10, 2,20 ]; let t2 = datatable(k:long, w:long)[ 1,100, 3,300 ]; let t3 = datatable(k:long, z:long)[ 2,7, 3,8 ]; t1 | join kind=fullouter (t2) on k | join kind=fullouter (t3) on k | project k, k1, k2, v, w, z | sort by v asc, w asc
datatable(x:long)[ 5, 3, 1, 4, 2 ] | sort by x asc | extend rn = row_number() | extend x = rn | sort by x desc | extend rn2 = row_number() | project rn, x, rn2
let base = datatable(k:long, v:long)[ 1,10, 1,20, 2,30 ]; let summ = base | summarize s = sum(v) by k; let mat = materialize(summ); mat | join kind=inner (mat | where s > 15) on k | extend diff = s - s1 | project k, s, s1, diff | sort by k asc
datatable(s:string, tag:string)[ "alpha","x", "Beta","x", "café","y", "","z", "O'Brien","x" ] | extend len = strlen(s) | summarize tot = sum(len), names = make_list(s) by tag | where tot > 0 | mv-expand n = names to typeof(string) | summarize cnt = count() by tag | sort by tag asc
let r0 = range i from 1 to 5 step 1; let r1 = r0 | extend j = i; let r2 = r1 | join kind=inner (r0 | project i2 = i) on $left.i == $right.i2; let r3 = r2 | extend k = i + i2; r3 | project i, i2, k | sort by i asc
datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ] | summarize dcount_v = count() by k | order by dcount_v desc, k asc | extend running = row_cumsum(dcount_v) | project k, dcount_v, running
print a = 1 | union (print a = 2) | union (print a = 3) | summarize s = sum(a), c = count() | extend mean = s / c
let d = datatable(d:dynamic)[ dynamic({"k":1,"vals":[10,20]}), dynamic({"k":2,"vals":[30]}) ]; let e = d | extend k = tolong(d.k), vals = d.vals; let f = e | mv-expand v = vals to typeof(long); let g = f | summarize total = sum(v), lst = make_list(v) by k; g | extend back = array_length(lst) | project k, total, back | sort by k asc
datatable(i:int, l:long)[ 1,100, 2,200, 3,300 ] | extend select = i, from = l, where = i + l | project from, where, select | extend order = from - select | project-reorder order, from, where, select | sort by select asc
let s = datatable(g:string, v:long)[ "a",1, "a",2, "a",3, "b",4, "b",5 ]; let agg = s | summarize lst = make_list(v), mn = min(v), mx = max(v) by g; let norm = agg | mv-apply x = lst to typeof(long) on (extend scaled = (x - mn) * 1.0 / (mx - mn) | summarize avgscaled = avg(scaled)); norm | project g, avgscaled | sort by g asc
datatable(k:long, v:long)[ 1,10, 2,20, 3,30 ] | extend v = v + 1 | summarize sum_v = sum(v) by k | extend v = sum_v | summarize sum(v) by k | project k, sum_v1 = sum_v | sort by k asc
let p = datatable(k:long)[ 1, 2, 3 ]; let q = p | extend grp = "g"; let r = q | summarize lst = make_list(k) by grp; let s2 = r | mv-expand k = lst to typeof(long); let t = s2 | join kind=inner (p) on k; t | project k, k1, grp | sort by k asc
datatable(x:long, y:long)[ 1,10, 2,20, 3,30 ] | extend tmp = x | extend x = y | extend y = tmp | project-away tmp | extend z = x - y | project x, y, z | sort by z asc
let m1 = materialize(range x from 1 to 4 step 1 | extend y = x * x); let m2 = materialize(m1 | where y > 2 | extend z = y + 1); m1 | join kind=inner (m2) on x | project x, y, y1, z | sort by x asc
datatable(g:string, v:long)[ "a",1, "a",2, "b",3 ] | summarize n = count(), s = sum(v) by g | union (datatable(g:string, v:long)[ "c",4 ] | summarize n = count(), s = sum(v) by g) | sort by g asc | extend rn = row_number() | project rn, g, n, s
let base = datatable(id:long, val:long)[ 1,100, 2,200, 3,300 ]; let withrn = base | sort by val desc | extend rank = row_number(); let top2 = withrn | where rank <= 2; let agg = top2 | summarize total = sum(val), lst = make_list(id); agg | extend ids = strcat_array(lst, ",") | project total, ids
datatable(k:long, v:long)[ 1,10, 1,20, 2,30, 2,30 ] | distinct k, v | summarize cnt = count(), lst = make_list(v) by k | mv-expand x = lst to typeof(long) | where x > 15 | summarize survivors = count() by k | sort by k asc
print outer = 1 | extend inner = toscalar(datatable(n:long)[ 10, 20, 30 ] | summarize sum(n)) | extend ratio = inner / outer | extend both = outer + inner | project outer, inner, ratio, both
let s1 = datatable(k:long, v:long)[ 1,10, 2,20, 3,30 ]; let s2 = s1 | extend bucket = bin(v, 20); let s3 = s2 | summarize cnt = count(), ks = make_list(k) by bucket; let s4 = s3 | sort by bucket asc | extend rn = row_number(); s4 | mv-expand kk = ks to typeof(long) | project bucket, rn, kk | sort by bucket asc, kk asc
